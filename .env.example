BOT_TOKEN=replace_with_telegram_bot_token
BOT_USERNAME=ProofStampBot

# 24-word signer mnemonic (Wallet V5R1). Keep only on server.
TON_SIGNER_MNEMONIC=replace_with_24_word_mnemonic

# Optional separate wallet for incoming TON payments (recommended).
TON_PAY_WALLET_ADDRESS=
TONCENTER_API_KEY=
TON_NETWORK=mainnet

# CAPTCHA/session
CAPTCHA_TTL_MINUTES=1440
PENDING_TTL_MINUTES=30

# Limits/timeouts
MAX_DOCUMENT_MB=20
FILE_FETCH_TIMEOUT_SEC=60

# Polling behavior
DROP_PENDING_UPDATES=true

# Health endpoint
PORT=3000

# Channel/group stamp mode
CHANNEL_STAMP_ENABLED=true
CHANNEL_STAMP_PIN_PROOF=false
GROUP_STAMP_MODE=manual
GROUP_STAMP_TAG=#stamp

# TON sweep to treasury
TREASURY_ADDRESS=
OP_RESERVE_TON=3
SWEEP_MARGIN_TON=0.2
SWEEP_INTERVAL_SEC=300
SWEEP_BACKOFF_SEC=300
SWEEP_AFTER_PAYMENT=false
